{
  "name": "eventra-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Eventra platform monorepo — Consumer, Business, and Admin surfaces on shared packages.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "check:workspaces": "node scripts/check-boundaries.mjs",
    "check:sql": "node scripts/check-sql-readiness.mjs",
    "check:pwa": "node scripts/check-pwa.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build && npm run check:workspaces && npm run check:sql && npm run check:pwa",
    "verify:persistence": "node scripts/verify-file-persistence.mjs",
    "preinstall:check": "node scripts/preinstall-check.mjs",
    "start:local": "node scripts/eventra-local.mjs",
    "start:admin": "node scripts/eventra-admin.mjs",
    "start:mobile": "node scripts/eventra-mobile.mjs",
    "reset:local": "node scripts/reset-local.mjs",
    "update:local": "node scripts/update-local.mjs",
    "shortcuts:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/install-shortcuts.ps1",
    "shortcuts:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/uninstall-shortcuts.ps1",
    "icon:make": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/make-icon.ps1",
    "test:business": "npm run test --workspace @eventra/business",
    "test:consumer": "npm run test --workspace @eventra/consumer",
    "test:admin": "npm run test --workspace @eventra/admin",
    "test:packages": "npm run test --workspace @eventra/types --workspace @eventra/config --workspace @eventra/calendar --workspace @eventra/entitlements --workspace @eventra/identity",
    "build:business": "npm run build --workspace @eventra/business",
    "build:consumer": "npm run build --workspace @eventra/consumer",
    "build:admin": "npm run build --workspace @eventra/admin",
    "desktop:admin:dev": "npm run desktop:dev --workspace @eventra/admin",
    "desktop:admin:build": "npm run desktop:build --workspace @eventra/admin",
    "desktop:business:prepare": "npm run desktop:prepare --workspace @eventra/business",
    "desktop:business:dev": "npm run desktop:dev --workspace @eventra/business",
    "desktop:business:build": "npm run desktop:build --workspace @eventra/business",
    "desktop:mobile:dev": "npm run desktop:dev --workspace @eventra/consumer",
    "desktop:mobile:build": "npm run desktop:build --workspace @eventra/consumer",
    "desktop:business-admin:dev": "npm run desktop:dev --workspace @eventra/business-admin",
    "desktop:business-admin:build": "npm run desktop:build --workspace @eventra/business-admin"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "p-map": "^4.0.0"
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true,
    "unrs-resolver@1.12.2": true
  }
}
