# Eventra API / services — environment (SERVER-side). Real secrets go in the
# deployment secret manager, NEVER committed. This lists required/optional keys only.
EVENTRA_ENV=local                 # local | test | development | staging | production
# --- Supabase (per-env project; NOT provisioned yet) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only
SUPABASE_JWT_SECRET=              # server-only (RLS bridge)
# --- Shopify (business integration; not connected yet) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=               # server-only
# --- Feature gate ---
EVENTRA_PERSISTENCE=false
