# Eventra Consumer — environment (client SPA). NO secrets (client-exposed).
# Copy to .env.local. Only VITE_-prefixed vars reach the client bundle.
VITE_EVENTRA_ENV=local            # local | test | development | staging | production
VITE_API_BASE_URL=                # shared API base (future); empty = mock/foundation
VITE_ENABLE_ADS=false             # foundation: ads engine not connected
