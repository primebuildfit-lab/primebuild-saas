{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eventra Mobile",
  "version": "0.2.0",
  "identifier": "com.eventra.mobile",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1421 --strictPort",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Eventra Mobile",
        "width": 420,
        "height": 880,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Eventra",
    "homepage": "https://eventra.app",
    "category": "Productivity",
    "shortDescription": "Eventra Mobile — your commercial calendar and deal alerts.",
    "longDescription": "Phone-form-factor shell for the Eventra Consumer app (apps/consumer). Plan around the commercial dates that matter and follow verified-deal alerts. Connects to the same Eventra services as the web/PWA app; no data is duplicated locally.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["eventra-mobile"]
      }
    },
    "updater": {
      "pubkey": "REPLACE_WITH_PRODUCTION_PUBKEY",
      "endpoints": [
        "https://github.com/primebuildfit-lab/primebuild-saas/releases/download/eventra-mobile/latest-mobile.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
