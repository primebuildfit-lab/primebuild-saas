{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eventra Business Admin",
  "version": "0.1.1",
  "identifier": "com.eventra.business.admin",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1430 --strictPort",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Eventra Business Admin",
        "width": 1500,
        "height": 950,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "publisher": "Eventra",
    "homepage": "https://eventra.app",
    "category": "Business",
    "shortDescription": "Eventra Business Admin — internal monitoring console.",
    "longDescription": "Private Windows desktop app for the Eventra Business Admin (apps/business-admin): the internal console that monitors, reviews, diagnoses and audits the commercial Eventra Business Client used by client companies. Connects to the same Eventra services as the web console; no data is duplicated locally. This desktop build wraps ONLY the Business Admin — never the client-facing Business app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["eventra-business-admin"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFNUQ3NzFDRUYxRDg4NDQKUldSRWlCM3ZISGRkemxHcFc5YXp5b1c0VkdybnpWWjhaSzhkV2M0NFRoakIwbGdwc3RhSHRWTTcK",
      "endpoints": [
        "https://github.com/primebuildfit-lab/primebuild-saas/releases/download/business-admin-latest/latest-business-admin.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
