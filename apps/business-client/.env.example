# Eventra environment — Phase 5 private pilot.
# Copy to .env and fill in when connecting real Shopify + Supabase.
# .env is gitignored — never commit real secrets.

# --- Shopify app (created via `shopify app config link`) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
# Minimal scope for the pilot (product/collection attach). No write scopes.
SCOPES=read_products

# --- Eventra Supabase (a NEW, SEPARATE project — NEVER primebuild-core) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role is used ONLY in server code (loaders/actions) to provision a store
# + membership on install and for admin tasks. Never expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret of the Eventra Supabase project — the server signs short-lived tokens
# whose `sub` claim carries the verified user_id, so RLS `auth.uid()` matches
# (docs/SECURITY_PLAN.md §4, Option A). Never sent to the client.
SUPABASE_JWT_SECRET=

# --- Persistence mode (MM4/MM5) ---
# When EVENTRA_PERSISTENCE=true AND all four SUPABASE_* vars are set, Eventra uses
# the Supabase adapter (RLS). Otherwise it uses mock (default) or file mode.
EVENTRA_PERSISTENCE=false
# Optional local dev persistence WITHOUT any cloud: "file" writes a JSON snapshot
# that survives server restarts. Leave unset for in-memory "mock" (ephemeral).
#   values: (unset|mock) | file
EVENTRA_PERSISTENCE_MODE=
# Optional path for file mode (default: .eventra/dev-store.json, gitignored).
EVENTRA_PERSISTENCE_FILE=

# --- Local preview (MM5, dev only) ---
# When true (and NODE_ENV!=production and not Supabase mode), /app renders the
# Business UI WITHOUT a Shopify session for local inspection. Clearly labeled;
# never impersonates OAuth. Never set this in production.
EVENTRA_PREVIEW=false

# --- Shopify session storage (Prisma/SQLite by default; unchanged for the pilot) ---
# Optional: point Prisma at Postgres instead of SQLite for a hosted pilot.
DATABASE_URL=

# --- Runtime ---
# Standard Node environment. Production hardening (fail-loud on missing secrets,
# no preview) keys off this.
#   values: development | production | test
NODE_ENV=development

# ============================================================================
# PREPARED — reserved keys the roadmap will read as each feature lands. They are
# documented here so ops can provision them once; today the code does NOT depend
# on them (mock/file mode ignores them). Do not assume a feature is active just
# because its key is set.
# ============================================================================

# --- Billing (Bloque 13 — prepared, no real charges until wired) ---
# Keep Shopify Billing in test mode until Brian authorizes real charges.
#   values: true (managed pricing / test) | false (live charges — Brian-gated)
BILLING_TEST_MODE=true

# --- Observability (Bloque 17 — prepared) ---
#   values: error | warn | info | debug
LOG_LEVEL=info
# Error-reporting DSN (e.g. Sentry). Leave blank to disable.
OBSERVABILITY_DSN=

# --- Standalone auth (Bloque 3/16 — prepared for the future non-Shopify SaaS) ---
# Secrets for a standalone identity provider + at-rest encryption once Eventra runs
# outside Shopify. Unused while auth is Shopify-session-based.
SESSION_SECRET=
ENCRYPTION_SECRET=

# --- Feature flags (prepared) ---
# Comma-separated flags for gradual rollout. Unknown/blank = all defaults.
EVENTRA_FEATURE_FLAGS=
